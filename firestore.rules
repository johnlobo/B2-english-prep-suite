rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      // 'admin@b2mastery.es' covers the very first login, before any user doc exists yet
      // (see the bootstrap flow in Auth.tsx). Once a user doc exists, its own 'role' field
      // is authoritative — this must match what the app UI uses to decide who sees the admin
      // tabs, or an account promoted to admin via the Users panel gets the UI but not the
      // actual Firestore access.
      return isSignedIn() && (
        request.auth.token.email == 'admin@b2mastery.es' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // Rules for system setup
    match /system/{documentId} {
      allow read: if true;
      // Every legitimate write path (admin bootstrap password change, Sheets sync, content reset)
      // runs while already signed in as the admin (isAdmin() checks the auth token email directly,
      // so it works even before any Firestore user doc exists). There is no flow that needs an
      // unauthenticated/pre-setup write bypass, so none is granted here.
      allow write: if isAdmin();
    }

    // Rules for users
    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow write: if isSignedIn() && (isOwner(userId) || isAdmin());
    }

    // Rules for progress
    match /progress/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow write: if isSignedIn() && (isOwner(userId) || isAdmin());
    }

    // Rules for notes
    match /notes/{noteId} {
      allow read: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow write: if isSignedIn() && (request.resource == null || request.resource.data.userId == request.auth.uid);
    }

    // Rules for study content (modules: theory, practice questions, control exams, podcasts).
    // Readable by any signed-in student; only admins (via Sheets sync or the reset action) can write.
    match /content/{moduleId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
