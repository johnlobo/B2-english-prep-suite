# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_ADMIN_BOOTSTRAP_PASSWORD: One-time password used to create the very first
# admin@b2mastery.es account in Firebase Auth on first login. Only relevant before
# initial setup is completed (see Auth.tsx / firestore system/setup doc). Leave unset
# in deployments where setup is already done.
VITE_ADMIN_BOOTSTRAP_PASSWORD="ChangeMeBeforeFirstLogin!"

# FIREBASE_SERVICE_ACCOUNT_KEY_BASE64: Required for server.ts to verify Firebase ID tokens
# (see serverAuth.ts) on /api/tutor/*, /api/sheets/sync and /api/export-excel. Generate one in
# the Firebase Console: Project Settings > Service Accounts > Generate new private key, then
# base64-encode the downloaded JSON file, e.g.:
#   base64 -w0 service-account.json
FIREBASE_SERVICE_ACCOUNT_KEY_BASE64="MY_BASE64_ENCODED_SERVICE_ACCOUNT_JSON"
